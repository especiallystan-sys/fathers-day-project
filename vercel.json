{
  "version": 2,
  "buildCommand": "cd frontend && npm ci && npm run build",
  "outputDirectory": "frontend/build",
  "framework": "react",
  "regions": ["iad1"],
  "env": {
    "REACT_APP_API_URL": "@react_app_api_url",
    "MONGO_URL": "@mongo_url",
    "DB_NAME": "@db_name",
    "CORS_ORIGINS": "@cors_origins"
  },
  "public": false
}
